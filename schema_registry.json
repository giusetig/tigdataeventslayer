{
  "schema_registry": {
    "version": "1.2",
    "domain": "TigDataEvents",
    "description": "Gestione eventi, registrazioni e utenti per piattaforme LiveForum",
    "external_systems": {
      "mTicket": {
        "description": "Piattaforma di ticketing esterna gestita da gruppo separato",
        "integration_point": "ProductId presente in PromotionType",
        "note": "Ogni tipo di invitation corrisponde a un ProductId su mTicket"
      }
    },
    "databases": {
      "primary": {
        "type": "sqlserver",
        "name": "TigDataEvents",
        "description": "Database principale per persistenza"
      },
      "cache": {
        "type": "redis",
        "description": "Cache per dati ad alta lettura",
        "ttl_strategy": {
          "description": "TTL dinamico basato sulla distanza dalla data evento",
          "rules": [
            {
              "condition": "days_to_event > 14",
              "ttl_seconds": 3600,
              "label": "Fase early - iscrizioni lente"
            },
            {
              "condition": "days_to_event BETWEEN 3 AND 14",
              "ttl_seconds": 900,
              "label": "Fase intermedia - iscrizioni in crescita"
            },
            {
              "condition": "days_to_event BETWEEN 0 AND 3",
              "ttl_seconds": 60,
              "label": "Fase finale - iscrizioni frequenti"
            },
            {
              "condition": "event_day",
              "ttl_seconds": 0,
              "label": "Durante evento - nessuna cache, dati real time"
            }
          ]
        }
      }
    },
    "entities": {
      "User": {
        "description": "Utente della piattaforma",
        "table": "dbo.User",
        "primary_key": "UserId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "user:{UserId}",
          "ttl_seconds": 1800,
          "invalidate_on": ["update", "delete"]
        },
        "fields": {
          "UserId": { "type": "int", "readonly": true },
          "Email": { "type": "string", "required": true, "unique": true },
          "Firstname": { "type": "string", "required": true },
          "Lastname": { "type": "string", "required": true },
          "CompanyName": { "type": "string" },
          "RoleId": {
            "type": "enum",
            "values": ["VISITOR", "SPEAKER", "EXHIBITOR", "PRESS", "SPONSOR", "STAFF"],
            "required": true
          },
          "Enabled": { "type": "bool", "default": false },
          "PrivacyAccepted": { "type": "bool", "required": true }
        },
        "rules": [
          {
            "id": "USR001",
            "type": "delete_constraint",
            "description": "Un utente non può essere eliminato se ha registrazioni attive",
            "condition": "NOT EXISTS (SELECT 1 FROM Registrazione WHERE UserId = @UserId AND Stato = 'ATTIVA')",
            "error_message": "Impossibile eliminare: l'utente ha registrazioni attive"
          },
          {
            "id": "USR002",
            "type": "unique_constraint",
            "description": "Email unica su tutto il sistema",
            "fields": ["Email"],
            "error_message": "Email già registrata nel sistema"
          },
          {
            "id": "USR003",
            "type": "insert_rule",
            "description": "Alla creazione l'utente è disabilitato finché non completa l'onboarding",
            "action": "SET Enabled = false"
          },
          {
            "id": "USR004",
            "type": "role_precedence",
            "description": "Se un utente è sia Speaker che Exhibitor il badge mostra Speaker",
            "condition": "RoleId IN ('SPEAKER', 'EXHIBITOR')",
            "action": "Badge mostra SPEAKER"
          }
        ],
        "intents": {
          "get_by_email": "Recupera utente per email",
          "get_by_event": "Recupera tutti gli utenti registrati a un evento",
          "get_by_invitation_uid": "Recupera dati parziali tramite UID per precompilare onboarding",
          "search": "Ricerca per nome, cognome o azienda",
          "enable": "Abilita utente dopo completamento onboarding",
          "disable": "Disabilita utente"
        }
      },
      "UserPhoto": {
        "description": "Foto profilo dell'utente, opzionale",
        "table": "dbo.UserPhoto",
        "primary_key": "UserId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "user_photo:{UserId}",
          "ttl_seconds": 7200,
          "invalidate_on": ["update", "delete"],
          "comment": "Le foto cambiano raramente, TTL alto"
        },
        "fields": {
          "UserId": {
            "type": "int",
            "required": true,
            "foreign_key": "User.UserId",
            "description": "Relazione 1:1 con User"
          },
          "ImageData": {
            "type": "image",
            "required": true,
            "description": "Dati binari dell'immagine"
          },
          "FileExtension": {
            "type": "string",
            "required": true,
            "values": ["jpg", "png", "gif", "webp"],
            "description": "Estensione rilevata automaticamente dai magic bytes"
          }
        },
        "rules": [
          {
            "id": "PHO001",
            "type": "format_constraint",
            "description": "Il formato dell'immagine viene rilevato automaticamente dai magic bytes",
            "supported_formats": ["jpg", "png", "gif", "webp"],
            "error_message": "Formato immagine non supportato"
          },
          {
            "id": "PHO002",
            "type": "optional_rule",
            "description": "La foto non è obbligatoria, può essere caricata da frontend (onboarding) o da Backoffice"
          }
        ],
        "intents": {
          "upload": "Carica o aggiorna la foto profilo",
          "delete": "Rimuove la foto profilo",
          "get": "Recupera la foto profilo di un utente"
        }
      },
      "PromotionType": {
        "description": "Tipi di invitation/promotion code con relativi accessi e sconti",
        "table": "dbo.PromotionType",
        "primary_key": "IdPromotionType",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "promotion_types",
          "ttl_seconds": 86400,
          "invalidate_on": ["update"],
          "comment": "Dati statici, TTL di 24 ore"
        },
        "fields": {
          "IdPromotionType": { "type": "int", "readonly": true },
          "PromotionTypeName": { "type": "string", "required": true },
          "SectionId": {
            "type": "int",
            "description": "TO_DO: verificare cosa rappresenta SectionId"
          },
          "ProductId": {
            "type": "int",
            "required": true,
            "description": "ID prodotto sulla piattaforma mTicket — usato per la gestione del ticketing",
            "external_system": "mTicket"
          },
          "ProductIdAfterEvent": {
            "type": "int",
            "description": "ID prodotto mTicket per acquisti post-evento",
            "external_system": "mTicket"
          }
        },
        "known_values": [
          {
            "IdPromotionType": 1,
            "PromotionTypeName": "Invitation code",
            "days_access": 1,
            "discount_percent": 100,
            "ProductId": 752
          },
          {
            "IdPromotionType": 3,
            "PromotionTypeName": "IC multiuso",
            "days_access": 2,
            "discount_percent": 100,
            "ProductId": 752
          },
          {
            "IdPromotionType": 4,
            "PromotionTypeName": "Sconto 50",
            "days_access": 1,
            "discount_percent": 50,
            "ProductId": 751
          },
          {
            "IdPromotionType": 5,
            "PromotionTypeName": "IC multiuso sconto 50",
            "days_access": 2,
            "discount_percent": 50,
            "ProductId": 769
          }
        ],
        "note": "days_access e discount_percent sono derivati dalla semantica del nome — TO_DO: verificare se esistono colonne dedicate o se vanno aggiunte"
      },
      "InvitationCode": {
        "description": "Invitation/promotion code generato dallo Sponsor e inviato via email",
        "table": "dbo.InvitationCode",
        "primary_key": "InvitationCodeId",
        "cache_strategy": {
          "enabled": false,
          "comment": "Dato transazionale, non cachato"
        },
        "fields": {
          "InvitationCodeId": { "type": "int", "readonly": true },
          "SponsorId": {
            "type": "int",
            "required": true,
            "foreign_key": "Sponsor.SponsorId"
          },
          "EventoId": {
            "type": "int",
            "required": true,
            "foreign_key": "Evento.EventoId"
          },
          "Email": {
            "type": "string",
            "required": true,
            "description": "Email del destinatario inserita dallo Sponsor"
          },
          "RuoloAssegnato": {
            "type": "enum",
            "values": ["VISITOR", "STAFF"],
            "required": true,
            "description": "Ruolo assegnato dallo Sponsor al momento della creazione"
          },
          "IdPromotionType": {
            "type": "int",
            "required": true,
            "foreign_key": "PromotionType.IdPromotionType",
            "description": "Determina sconto e giorni di accesso"
          },
          "UID": {
            "type": "guid",
            "readonly": true,
            "unique": true,
            "description": "Identificativo univoco incluso nel link in querystring per precompilare l'onboarding"
          },
          "Stato": {
            "type": "enum",
            "values": ["INVIATO", "APERTO", "COMPLETATO", "SCADUTO"],
            "default": "INVIATO"
          },
          "DataInvio": {
            "type": "datetime",
            "readonly": true,
            "default": "NOW()"
          },
          "DataUtilizzo": {
            "type": "datetime",
            "nullable": true,
            "description": "Valorizzato quando l'utente completa l'onboarding"
          }
        },
        "rules": [
          {
            "id": "IC001",
            "type": "duplicate_constraint",
            "description": "Non si può inviare due invitation attivi alla stessa email per lo stesso evento",
            "condition": "NOT EXISTS (SELECT 1 FROM InvitationCode WHERE Email = @Email AND EventoId = @EventoId AND Stato NOT IN ('SCADUTO', 'COMPLETATO'))",
            "error_message": "Esiste già un invitation attivo per questa email per questo evento"
          },
          {
            "id": "IC002",
            "type": "insert_rule",
            "description": "Il UID viene generato automaticamente alla creazione",
            "action": "SET UID = NEWID()"
          },
          {
            "id": "IC003",
            "type": "monouso_constraint",
            "description": "Un invitation code può essere utilizzato da un solo utente",
            "condition": "Stato NOT IN ('COMPLETATO')",
            "error_message": "Questo invitation code è già stato utilizzato"
          },
          {
            "id": "IC004",
            "type": "state_rule",
            "description": "Quando l'utente completa l'onboarding lo stato diventa COMPLETATO",
            "trigger": "User.onboarding_completed WHERE UID = @UID",
            "action": "SET Stato = 'COMPLETATO', DataUtilizzo = NOW()"
          },
          {
            "id": "IC005",
            "type": "sponsor_constraint",
            "description": "Uno Sponsor può vedere e gestire solo i propri invitation",
            "filter": "SponsorId = @CurrentSponsorId"
          }
        ],
        "intents": {
          "create": "Crea e invia un nuovo invitation code",
          "get_by_uid": "Recupera dati parziali tramite UID per precompilare onboarding",
          "get_by_sponsor": "Recupera tutti gli invitation di uno Sponsor con stato",
          "get_utilized": "Recupera invitation convertiti in registrazione",
          "get_pending": "Recupera invitation ancora non utilizzati",
          "expire": "Marca un invitation come scaduto"
        }
      },
      "Sponsor": {
        "description": "Azienda sponsor di un evento con utenza Backoffice",
        "table": "dbo.Sponsor",
        "primary_key": "SponsorId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "sponsor:{SponsorId}",
          "ttl_seconds": 3600,
          "invalidate_on": ["update"]
        },
        "fields": {
          "SponsorId": { "type": "int", "readonly": true },
          "EventoId": {
            "type": "int",
            "required": true,
            "foreign_key": "Evento.EventoId",
            "description": "Uno Sponsor è sempre legato a un singolo evento"
          },
          "RagioneSociale": { "type": "string", "required": true },
          "LogoUrl": { "type": "string" },
          "BackofficeUsername": {
            "type": "string",
            "required": true,
            "unique": true
          },
          "BackofficePasswordHash": {
            "type": "string",
            "required": true
          },
          "Livello": {
            "type": "enum",
            "values": ["GOLD", "SILVER", "BRONZE", "PARTNER"],
            "description": "TO_DO: verificare i livelli reali usati"
          }
        },
        "rules": [
          {
            "id": "SPO001",
            "type": "visibility_constraint",
            "description": "Uno Sponsor vede solo i propri Speaker, Exhibitor e InvitationCode",
            "filter": "SponsorId = @CurrentSponsorId",
            "applies_to": ["User", "InvitationCode"]
          },
          {
            "id": "SPO002",
            "type": "insert_constraint",
            "description": "Uno Sponsor può registrare solo Speaker ed Exhibitor",
            "condition": "RuoloAssegnato IN ('SPEAKER', 'EXHIBITOR')",
            "error_message": "Lo Sponsor può registrare solo Speaker ed Exhibitor"
          }
        ],
        "intents": {
          "get_own_speakers": "Recupera i propri Speaker",
          "get_own_exhibitors": "Recupera i propri Exhibitor",
          "get_own_invitations": "Recupera invitation inviati con stato",
          "get_invitation_stats": "Statistiche invitation: inviati, aperti, completati",
          "register_speaker": "Registra un nuovo Speaker",
          "register_exhibitor": "Registra un nuovo Exhibitor",
          "generate_invitation": "Genera e invia un invitation code a un Visitor"
        }
      },
      "Evento": {
        "description": "Evento o edizione di un evento",
        "table": "dbo.Evento",
        "primary_key": "EventoId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "evento:{EventoId}",
          "ttl_strategy": "dynamic",
          "invalidate_on": ["update"]
        },
        "fields": {
          "EventoId": { "type": "int", "readonly": true },
          "Nome": { "type": "string", "required": true },
          "DataInizio": { "type": "datetime", "required": true },
          "DataFine": { "type": "datetime", "required": true },
          "NumeroGiorni": {
            "type": "int",
            "readonly": true,
            "description": "Calcolato da DataFine - DataInizio, usato per validare i PromotionType multiuso"
          },
          "Sede": { "type": "string" },
          "MaxPartecipanti": { "type": "int", "nullable": true },
          "Stato": {
            "type": "enum",
            "values": ["BOZZA", "PUBBLICATO", "CHIUSO", "ANNULLATO"],
            "default": "BOZZA"
          },
          "RegistrazioniAperte": {
            "type": "bool",
            "default": false,
            "description": "Flag che abilita le registrazioni dal frontend"
          }
        },
        "rules": [
          {
            "id": "EVT001",
            "type": "date_constraint",
            "description": "La data di fine deve essere successiva alla data di inizio",
            "condition": "DataFine > DataInizio",
            "error_message": "La data di fine deve essere successiva alla data di inizio"
          },
          {
            "id": "EVT002",
            "type": "state_machine",
            "description": "Transizioni di stato consentite",
            "transitions": {
              "BOZZA": ["PUBBLICATO", "ANNULLATO"],
              "PUBBLICATO": ["CHIUSO", "ANNULLATO"],
              "CHIUSO": [],
              "ANNULLATO": []
            }
          },
          {
            "id": "EVT003",
            "type": "delete_constraint",
            "description": "Un evento non può essere eliminato se ha registrazioni",
            "condition": "NOT EXISTS (SELECT 1 FROM Registrazione WHERE EventoId = @EventoId)",
            "error_message": "Impossibile eliminare: esistono registrazioni associate"
          }
        ],
        "intents": {
          "get_active": "Recupera eventi con registrazioni aperte",
          "get_with_stats": "Recupera evento con statistiche registrazioni",
          "get_agenda": "Recupera agenda completa con sessioni e relatori",
          "publish": "Pubblica un evento",
          "open_registrations": "Apre le registrazioni dal frontend",
          "close_registrations": "Chiude le registrazioni"
        }
      },
      "Sessione": {
        "description": "Sessione o workshop nell'agenda di un evento",
        "table": "dbo.Sessione",
        "primary_key": "SessioneId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "sessioni:evento:{EventoId}",
          "ttl_seconds": 7200,
          "invalidate_on": ["update"],
          "comment": "L'agenda cambia raramente, TTL alto"
        },
        "fields": {
          "SessioneId": { "type": "int", "readonly": true },
          "EventoId": {
            "type": "int",
            "required": true,
            "foreign_key": "Evento.EventoId"
          },
          "Titolo": { "type": "string", "required": true },
          "Descrizione": { "type": "string" },
          "OraInizio": { "type": "datetime", "required": true },
          "OraFine": { "type": "datetime", "required": true },
          "Sala": { "type": "string" },
          "Tipo": {
            "type": "enum",
            "values": ["KEYNOTE", "TALK", "WORKSHOP", "PANEL"],
            "description": "TO_DO: verificare i tipi reali usati"
          }
        },
        "rules": [
          {
            "id": "SES001",
            "type": "date_constraint",
            "description": "La sessione deve essere compresa nelle date dell'evento",
            "condition": "OraInizio >= Evento.DataInizio AND OraFine <= Evento.DataFine",
            "error_message": "La sessione deve essere compresa nelle date dell'evento"
          }
        ],
        "intents": {
          "get_agenda": "Recupera agenda completa ordinata per orario",
          "get_by_speaker": "Recupera sessioni di uno Speaker specifico",
          "get_with_speakers": "Recupera sessioni con elenco relatori"
        }
      },
      "SessioneSpeaker": {
        "description": "Associazione tra Speaker e Sessione — uno Speaker può essere in più sessioni",
        "table": "dbo.SessioneSpeaker",
        "primary_key": ["SessioneId", "UserId"],
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "speakers:sessione:{SessioneId}",
          "ttl_seconds": 7200,
          "invalidate_on": ["insert", "delete"]
        },
        "fields": {
          "SessioneId": {
            "type": "int",
            "required": true,
            "foreign_key": "Sessione.SessioneId"
          },
          "UserId": {
            "type": "int",
            "required": true,
            "foreign_key": "User.UserId"
          }
        },
        "rules": [
          {
            "id": "SS001",
            "type": "role_constraint",
            "description": "Solo utenti con ruolo Speaker possono essere associati a una sessione",
            "condition": "(SELECT RoleId FROM User WHERE UserId = @UserId) = 'SPEAKER'",
            "error_message": "Solo gli Speaker possono essere associati a una sessione"
          }
        ],
        "intents": {
          "add_speaker": "Aggiunge uno Speaker a una sessione",
          "remove_speaker": "Rimuove uno Speaker da una sessione",
          "get_by_session": "Recupera tutti gli Speaker di una sessione"
        }
      },
      "Registrazione": {
        "description": "Registrazione di un utente a un evento",
        "table": "dbo.Registrazione",
        "primary_key": "RegistrazioneId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "reg_stats:evento:{EventoId}",
          "ttl_strategy": "dynamic",
          "comment": "Cachiamo solo le statistiche aggregate, non le singole registrazioni"
        },
        "fields": {
          "RegistrazioneId": { "type": "int", "readonly": true },
          "UserId": {
            "type": "int",
            "required": true,
            "foreign_key": "User.UserId"
          },
          "EventoId": {
            "type": "int",
            "required": true,
            "foreign_key": "Evento.EventoId"
          },
          "SponsorId": {
            "type": "int",
            "nullable": true,
            "foreign_key": "Sponsor.SponsorId",
            "description": "Valorizzato se registrato da Backoffice Sponsor"
          },
          "InvitationCodeId": {
            "type": "int",
            "nullable": true,
            "foreign_key": "InvitationCode.InvitationCodeId",
            "description": "Valorizzato se la registrazione è partita da un invitation"
          },
          "GiornoAccesso": {
            "type": "enum",
            "values": ["GIORNO_1", "GIORNO_2", "ENTRAMBI"],
            "required": true,
            "description": "Determinato dal PromotionType — multiuso = ENTRAMBI"
          },
          "Canale": {
            "type": "enum",
            "values": ["FRONTEND", "BACKOFFICE", "INVITATION"],
            "description": "Come è avvenuta la registrazione"
          },
          "Stato": {
            "type": "enum",
            "values": ["ATTIVA", "CANCELLATA", "IN_ATTESA"],
            "default": "ATTIVA"
          },
          "DataRegistrazione": {
            "type": "datetime",
            "readonly": true,
            "default": "NOW()"
          },
          "QRCode": {
            "type": "string",
            "readonly": true,
            "description": "Generato automaticamente alla registrazione"
          },
          "CheckInEffettuato": { "type": "bool", "default": false },
          "DataCheckIn": { "type": "datetime", "nullable": true }
        },
        "rules": [
          {
            "id": "REG001",
            "type": "duplicate_constraint",
            "description": "Un utente non può registrarsi due volte allo stesso evento",
            "condition": "NOT EXISTS (SELECT 1 FROM Registrazione WHERE UserId = @UserId AND EventoId = @EventoId AND Stato != 'CANCELLATA')",
            "error_message": "L'utente è già registrato a questo evento"
          },
          {
            "id": "REG002",
            "type": "capacity_constraint",
            "description": "Verifica capienza solo se MaxPartecipanti è valorizzato",
            "condition": "MaxPartecipanti IS NULL OR (SELECT COUNT(*) FROM Registrazione WHERE EventoId = @EventoId AND Stato = 'ATTIVA') < MaxPartecipanti",
            "error_message": "Evento al completo"
          },
          {
            "id": "REG003",
            "type": "state_constraint",
            "description": "Registrazioni frontend possibili solo se RegistrazioniAperte = true",
            "condition": "Canale != 'FRONTEND' OR (SELECT RegistrazioniAperte FROM Evento WHERE EventoId = @EventoId) = true",
            "error_message": "Le registrazioni per questo evento non sono aperte"
          },
          {
            "id": "REG004",
            "type": "insert_rule",
            "description": "Il QRCode viene generato automaticamente",
            "action": "SET QRCode = GENERATE_QRCODE(UserId, EventoId)"
          },
          {
            "id": "REG005",
            "type": "giorno_accesso_rule",
            "description": "GiornoAccesso viene impostato in base al PromotionType — se multiuso = ENTRAMBI",
            "action": "SET GiornoAccesso = IF(PromotionType.days_access = 2, 'ENTRAMBI', 'GIORNO_1')"
          },
          {
            "id": "REG006",
            "type": "checkin_rule",
            "description": "Il check-in imposta data e flag, verifica che il giorno sia accessibile",
            "condition": "GiornoAccesso = 'ENTRAMBI' OR GiornoAccesso = @GiornoCorrente",
            "action": "SET CheckInEffettuato = true, DataCheckIn = NOW()",
            "error_message": "L'utente non ha accesso per questo giorno dell'evento"
          }
        ],
        "intents": {
          "register_visitor": "Registra un Visitor dal frontend con o senza invitation code",
          "register_by_sponsor": "Registra Speaker o Exhibitor da Backoffice Sponsor",
          "cancel": "Cancella una registrazione",
          "checkin": "Effettua check-in tramite QRCode verificando il giorno di accesso",
          "get_by_event": "Recupera tutte le registrazioni di un evento",
          "get_by_sponsor": "Recupera registrazioni generate da uno Sponsor",
          "get_stats": "Statistiche aggregate con TTL dinamico basato su data evento"
        }
      }
    }
  }
}