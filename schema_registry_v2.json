          "TigDataEventsSponsorId": { "type": "guid", "deprecated": true, "note": "SCARTATO" }
        },
        "rules": [
          {
            "id": "SPO001",
            "type": "visibility_constraint",
            "description": "Uno Sponsor vede solo i propri Speaker, Exhibitor e InvitationCode",
            "filter": "SponsorId = @CurrentSponsorId",
            "applies_to": ["User", "UserInvitation", "PromotionCode"]
          },
          {
            "id": "SPO002",
            "type": "insert_constraint",
            "description": "Uno Sponsor può registrare solo Speaker ed Exhibitor tramite UserInvitation",
            "condition": "RoleId IN ('SPEAKER', 'EXHIBITOR')"
          }
        ],
        "intents": {
          "get_own_speakers": "Recupera i propri Speaker",
          "get_own_exhibitors": "Recupera i propri Exhibitor",
          "get_own_invitations": "Recupera invitation inviati con stato",
          "get_invitation_stats": "Statistiche invitation: inviati, aperti, completati",
          "register_speaker": "Registra un nuovo Speaker tramite UserInvitation",
          "register_exhibitor": "Registra un nuovo Exhibitor tramite UserInvitation",
          "generate_promotion_code": "Genera codici invito per Visitor"
        }
      },
      "UserInvitation": {
        "description": "Invito diretto per Speaker o Exhibitor. Gestito dallo Sponsor dal Backoffice. Sistema separato da PromotionCode.",
