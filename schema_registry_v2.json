{
  "schema_registry": {
    "version": "2.0",
    "domain": "TigDataEvents",
    "description": "Gestione eventi, registrazioni e utenti per piattaforme LiveForum",
    "last_updated": "2026-05-22",
    "changelog": {
      "2.0": "Aggiornamento post-analisi LiveForum_Netcomm_26 del 22 maggio 2026. Allineamento schema teorico con struttura reale del DB. Aggiunta entità Workshop, Order, Ticket, SponsorLevel, UserInvitation, PromotionCode. Correzione Sponsor e User. Rinomina Sessione in Workshop."
    },
    "external_systems": {
      "mTicket": {
        "description": "Piattaforma di ticketing esterna",
        "integration_point": "ProductId in PromotionType, IdFiera in CodiciSconto",
        "note": "IdFiera corrisponde a EventoId nel nuovo schema. Valore Netcomm_26: 229 (configurato in Web.config come IdFieraMTicket)"
      },
      "MICO": {
        "description": "Sistema esterno di networking/matchmaking tra aziende",
        "integration_point": "UsernameMico e PasswordMico in Sponsor",
        "note": "TODO T14: verificare se MICO è ancora attivo e cosa fa esattamente"
      },
      "FatturazioneElettronica": {
        "description": "Sistema esterno di fatturazione elettronica SDI",
        "integration_point": "InvoiceUID e InvoiceErrors in Order",
        "note": "Progetto separato che comunica con il DB tramite questi campi"
      },
      "GoogleAds": {
        "description": "Piattaforma advertising Google",
        "integration_point": "Servizio Tracker, account identificato da ExternalId (es. 797-174-4254 per Netcomm_26)",
        "note": "LoginCustomerId = 7971744254 configurato in Tracker.exe.config"
      },
      "FacebookAds": {
        "description": "Piattaforma advertising Meta/Facebook",
        "integration_point": "Servizio Tracker, account act_237789896626275",
        "note": "TODO T11: Enrico deve completare Data Use Checkup su app Meta 693451887484215"
      }
    },
    "databases": {
      "primary": {
        "type": "sqlserver",
        "name": "TigDataEvents",
        "instance": "tigevents-sqlmi.98086c461ef2.database.windows.net",
        "description": "Database principale su Azure SQL Managed Instance"
      },
      "cache": {
        "type": "redis",
        "description": "Cache per dati ad alta lettura",
        "ttl_strategy": {
          "description": "TTL dinamico basato sulla distanza dalla data evento",
          "rules": [
            { "condition": "days_to_event > 14", "ttl_seconds": 3600, "label": "Fase early" },
            { "condition": "days_to_event BETWEEN 3 AND 14", "ttl_seconds": 900, "label": "Fase intermedia" },
            { "condition": "days_to_event BETWEEN 0 AND 3", "ttl_seconds": 60, "label": "Fase finale" },
            { "condition": "event_day", "ttl_seconds": 0, "label": "Durante evento - real time" }
          ]
        }
      }
    },
    "entities": {
      "User": {
        "description": "Utente della piattaforma. Anagrafica unica cross-evento.",
        "table": "dbo.User",
        "primary_key": "UserId",
        "source_table": "LiveForum.dbo.User",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "user:{UserId}",
          "ttl_seconds": 1800,
          "invalidate_on": ["update", "delete"]
        },
        "fields": {
          "UserId": { "type": "int", "readonly": true },
          "Username": { "type": "string", "required": true },
          "Email": { "type": "string", "required": true, "unique": true },
          "ReferenceEmail": { "type": "string", "nullable": true },
          "Password": { "type": "string", "required": true, "note": "Hash" },
          "Enabled": { "type": "bool", "default": false },
          "Firstname": { "type": "string" },
          "Lastname": { "type": "string" },
          "CompanyName": { "type": "string" },
          "CleanCompanyName": { "type": "string", "note": "Versione normalizzata di CompanyName" },
          "Phone": { "type": "string" },
          "Mobile": { "type": "string" },
          "CultureId": { "type": "int", "foreign_key": "Culture.CultureId" },
          "CustomData": {
            "type": "nvarchar(max)",
            "note": "In LiveForum era XML. Nel nuovo schema è JSON. TODO T12: aggiornare codice di serializzazione nell'applicazione."
          },
          "UID": { "type": "guid", "unique": true, "note": "Usato nei link invitation per precompilare onboarding" },
          "QRCode": {
            "type": "string",
            "note": "Attualmente sull'utente. TODO T13: spostare su Registrazione in futuro quando si ritocca il codice applicativo."
          },
          "PrivacyAccepted": { "type": "bool", "required": true },
          "ThirdPartyPrivacy": { "type": "bool" },
          "TigDataEventsId": { "type": "guid", "deprecated": true, "note": "SCARTATO: non serve nel sistema unificato" },
          "IsOnline": { "type": "bool" },
          "IsOnSite": { "type": "bool" },
          "LastLogin": { "type": "datetime", "nullable": true },
          "Registered": { "type": "bool" },
          "MailReminderSent": { "type": "bool" }
        },
        "rules": [
          {
            "id": "USR001",
            "type": "delete_constraint",
            "description": "Un utente non può essere eliminato se ha registrazioni attive",
            "condition": "NOT EXISTS (SELECT 1 FROM Registrazione WHERE UserId = @UserId AND Stato = 'ATTIVA')",
            "error_message": "Impossibile eliminare: l'utente ha registrazioni attive"
          },
          {
            "id": "USR002",
            "type": "unique_constraint",
            "description": "Email unica su tutto il sistema",
            "fields": ["Email"],
            "error_message": "Email già registrata nel sistema"
          },
          {
            "id": "USR003",
            "type": "insert_rule",
            "description": "Alla creazione l'utente è disabilitato finché non completa l'onboarding",
            "action": "SET Enabled = false"
          },
          {
            "id": "USR004",
            "type": "migration_note",
            "description": "CustomData: in migrazione convertire XML esistente in JSON con script SQL"
          }
        ],
        "intents": {
          "get_by_email": "Recupera utente per email",
          "get_by_event": "Recupera tutti gli utenti registrati a un evento",
          "get_by_invitation_uid": "Recupera dati parziali tramite UID per precompilare onboarding",
          "search": "Ricerca per nome, cognome o azienda",
          "enable": "Abilita utente dopo completamento onboarding",
          "disable": "Disabilita utente"
        }
      },
      "UserPhoto": {
        "description": "Foto profilo dell'utente, opzionale",
        "table": "dbo.UserPicture",
        "primary_key": "UserId",
        "note": "Nel LiveForum la tabella si chiama UserPicture, non UserPhoto",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "user_photo:{UserId}",
          "ttl_seconds": 7200,
          "invalidate_on": ["update", "delete"]
        },
        "fields": {
          "UserId": { "type": "int", "required": true, "foreign_key": "User.UserId" },
          "Picture": { "type": "image", "required": true },
          "FileType": { "type": "string", "values": ["jpg", "png", "gif", "webp"] }
        },
        "rules": [
          {
            "id": "PHO001",
            "type": "format_constraint",
            "description": "Formato immagine rilevato dai magic bytes",
            "supported_formats": ["jpg", "png", "gif", "webp"],
            "error_message": "Formato immagine non supportato"
          }
        ],
        "intents": {
          "upload": "Carica o aggiorna la foto profilo",
          "delete": "Rimuove la foto profilo",
          "get": "Recupera la foto profilo di un utente"
        }
      },
      "LogoConfiguration": {
        "description": "Configurazione dimensioni logo per i livelli sponsor. Tabella di lookup statica.",
        "table": "dbo.LogoConfiguration",
        "primary_key": "LogoConfigurationId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "logo_configurations",
          "ttl_seconds": 86400,
          "comment": "Dato statico, TTL 24 ore"
        },
        "fields": {
          "LogoConfigurationId": { "type": "tinyint", "readonly": true },
          "Width": { "type": "smallint", "required": true },
          "Height": { "type": "smallint", "required": true }
        },
        "known_values": [
          { "LogoConfigurationId": 1, "Width": 255, "Height": 128 }
        ]
      },
      "SponsorLevel": {
        "description": "Livello/categoria sponsor per evento. I livelli cambiano da evento a evento — non sono un enum fisso.",
        "table": "dbo.SponsorLevel",
        "primary_key": "SponsorLevelId",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "sponsor_levels:evento:{EventoId}",
          "ttl_seconds": 3600,
          "invalidate_on": ["update"]
        },
        "fields": {
          "SponsorLevelId": { "type": "tinyint", "readonly": true },
          "EventoId": {
            "type": "int",
            "required": true,
            "foreign_key": "Evento.EventoId",
            "note": "Aggiunto in fase di migrazione per supporto multi-evento. TODO T16."
          },
          "Name": { "type": "string", "required": true },
          "LogoConfigurationId": {
            "type": "tinyint",
            "foreign_key": "LogoConfiguration.LogoConfigurationId",
            "note": "Usato nel Backoffice per dimensioni logo sponsor"
          },
          "SponsorLevelPriority": { "type": "int", "note": "Ordine di visualizzazione" }
        },
        "known_values_netcomm26": [
          { "SponsorLevelId": 2, "Name": "Un evento di", "Priority": 5 },
          { "SponsorLevelId": 3, "Name": "Main Partner", "Priority": 10 },
          { "SponsorLevelId": 4, "Name": "Platinum Sponsor", "Priority": 15 },
          { "SponsorLevelId": 34, "Name": "Diamond Sponsor", "Priority": 12 },
          { "SponsorLevelId": 5, "Name": "Gold Sponsor", "Priority": 25 },
          { "SponsorLevelId": 8, "Name": "Silver Sponsor", "Priority": 50 },
          { "SponsorLevelId": 30, "Name": "Content Partner", "Priority": 40 },
          { "SponsorLevelId": 15, "Name": "Media Partner", "Priority": 77 },
          { "SponsorLevelId": 19, "Name": "Espositori", "Priority": 82 },
          { "SponsorLevelId": 26, "Name": "Startup", "Priority": 95 }
        ],
        "note": "Netcomm_26 ha 35 livelli diversi. Ogni evento definisce i propri livelli."
      },
      "Sponsor": {
        "description": "Azienda sponsor di un evento con utenza Backoffice",
        "table": "dbo.Sponsor",
        "primary_key": "SponsorId",
        "source_table": "LiveForum.dbo.Sponsor",
        "cache_strategy": {
          "enabled": true,
          "key_pattern": "sponsor:{SponsorId}",
          "ttl_seconds": 3600,
          "invalidate_on": ["update"]
        },
        "fields": {
          "SponsorId": { "type": "int", "readonly": true },
          "EventoId": { "type": "int", "required": true, "foreign_key": "Evento.EventoId" },
          "SponsorLevelId": { "type": "tinyint", "foreign_key": "SponsorLevel.SponsorLevelId" },
          "Name": { "type": "string", "required": true },
          "BusinessName": { "type": "string" },
          "BusinessAddress": { "type": "string" },
          "Address": { "type": "string" },
          "ZipCode": { "type": "string" },
          "City": { "type": "string" },
          "Province": { "type": "string" },
          "Country": { "type": "string" },
          "Website": { "type": "string" },
          "Email": { "type": "string" },
          "Phone": { "type": "string" },
          "VatNumber": { "type": "string", "required": true, "note": "Partita IVA" },
          "DomainEmail": { "type": "string", "note": "Domini email per riconoscimento automatico utenti sponsor" },
          "ReferrerName": { "type": "string" },
          "ReferrerEmail": { "type": "string" },
          "Url": { "type": "string", "note": "Logo URL" },
          "Online": { "type": "bool" },
          "Enabled": { "type": "bool" },
          "Priority": { "type": "int" },
          "StandPosition": { "type": "string" },
          "MetriQuadri": { "type": "string" },
          "AllestimentoStand": { "type": "string" },
          "UrlFacebook": { "type": "string" },
          "UrlLinkedn": { "type": "string" },
          "UrlTwitter": { "type": "string", "note": "Rinominare in UrlX in futuro" },
          "UID": { "type": "guid", "unique": true },
          "UsernameMico": { "type": "string", "note": "Credenziali sistema esterno MICO. TODO T14: verificare se ancora attivo." },
          "PasswordMico": { "type": "string", "note": "Credenziali sistema esterno MICO." },
          "DocumentPassword": { "type": "string", "note": "Password per documenti riservati sponsor. Usato nel codice." },
          "PasswordConferenceHall": { "type": "string", "note": "Password sala conferenze virtuale. Usato nel codice." },
