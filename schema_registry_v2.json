          "UID": { "type": "guid", "unique": true },
          "CultureId": { "type": "int", "nullable": true },
          "CustomData": { "type": "xml", "note": "TODO T12: convertire in JSON" },
          "InviteSent": { "type": "datetime", "nullable": true }
        },
        "note": "Sistema distinto da PromotionCode. UserInvitation = Speaker/Exhibitor. PromotionCode = Visitor."
      },
      "PromotionCode": {
        "description": "Codice invito per Visitor generato dallo Sponsor. Sistema distinto da UserInvitation.",
