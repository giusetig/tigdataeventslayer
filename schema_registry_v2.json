        "primary_key": "IdPromotionCode",
        "cache_strategy": { "enabled": false, "comment": "Dato transazionale" },
        "fields": {
          "IdPromotionCode": { "type": "int", "readonly": true },
          "Code": { "type": "varchar(10)", "required": true, "unique": true },
          "IdPromotionType": { "type": "tinyint", "foreign_key": "PromotionType.IdPromotionType" },
          "SponsorId": { "type": "int", "nullable": true, "foreign_key": "Sponsor.SponsorId" },
          "SectionId": { "type": "int" },
          "EventScheduleId": { "type": "int", "nullable": true },
          "DataValidita": { "type": "datetime", "nullable": true },
          "ProductId": { "type": "int", "nullable": true },
          "IdPromotionCodeOrder": { "type": "int", "nullable": true, "foreign_key": "PromotionCodeOrder.IdPromotionCodeOrder" },
